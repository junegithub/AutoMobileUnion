<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_white"
    android:orientation="vertical">

    <include
        android:id="@+id/title_layout"
        layout="@layout/fragment_title" />

    <!-- 筛选栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/margin_15"
        android:orientation="horizontal"
        android:weightSum="3">

        <!-- 全部报警下拉Spinner -->
        <Spinner
            android:id="@+id/spinner_alarm_type"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_marginEnd="@dimen/margin_10"
            android:layout_weight="1"
            android:background="@drawable/bg_spinner"
            android:entries="@array/alarm_types"
            android:gravity="center"
            android:popupBackground="@color/bg_white"
            android:textColor="@color/text_black"
            android:textSize="@dimen/text_company" />

        <!-- 日期选择TextView -->
        <TextView
            android:id="@+id/tv_date_range"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="2"
            android:background="@drawable/bg_date_text"
            android:gravity="center"
            android:textColor="@color/text_gray"
            android:textSize="@dimen/text_company" />
    </LinearLayout>

    <!-- 报警列表 -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_alarm_list"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginHorizontal="@dimen/margin_15" />

</LinearLayout>

<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <!-- 主答题区域 -->
    <ScrollView
        android:id="@+id/sv_main_content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="@dimen/exam_item_margin_vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingRight="@dimen/exam_item_padding_horizontal">

            <!-- 正确答案标题（仅查看模式显示） -->
            <TextView
                android:id="@+id/tv_correct_answer_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="正确答案"
                android:textSize="18sp"
                android:textAlignment="center"
                android:layout_marginBottom="@dimen/exam_item_margin_vertical"
                android:visibility="gone"/>

            <!-- 题目标题 -->
            <TextView
                android:id="@+id/tv_question_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="@dimen/exam_title_text_size"
                android:paddingVertical="5dp"
                android:textColor="#000000"
                android:background="@drawable/line_under"/>

            <!-- 单选选项容器 -->
            <LinearLayout
                android:id="@+id/ll_radio_options"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"/>

            <!-- 多选选项容器 -->
            <LinearLayout
                android:id="@+id/ll_checkbox_options"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"/>

            <!-- 填空题容器 -->
            <LinearLayout
                android:id="@+id/ll_textarea_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <EditText
                    android:id="@+id/et_textarea"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/exam_textarea_height"
                    android:hint="请输入您的答案"
                    android:textSize="@dimen/exam_option_text_size"
                    android:padding="10dp"
                    android:background="@drawable/textarea_border"
                    android:gravity="start|top"/>
            </LinearLayout>

            <!-- 按钮行 -->
            <LinearLayout
                android:id="@+id/ll_button_row"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:layout_marginVertical="@dimen/exam_item_margin_vertical">

                <Space
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1" />
                <!-- 上一题按钮 -->
                <Button
                    android:id="@+id/btn_last"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="上一题"
                    android:textSize="14sp"
                    android:layout_marginRight="@dimen/exam_item_margin_vertical"
                    android:visibility="gone"/>

                <!-- 下一题按钮 -->
                <Button
                    android:id="@+id/btn_next"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="下一题"
                    android:textSize="14sp"
                    android:visibility="gone"/>
                <Space
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1" />

                <!-- 题号文字 -->
                <TextView
                    android:id="@+id/tv_index_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="题号"
                    android:textColor="@color/gray"
                    android:visibility="visible"/>
            </LinearLayout>

            <!-- 提交按钮 -->
            <Button
                android:id="@+id/btn_finish"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="提交"
                android:textColor="#FFFFFF"
                android:backgroundTint="@color/exam_primary"
                android:visibility="gone"/>

            <!-- 题号盒子（内嵌式） -->
            <LinearLayout
                android:id="@+id/ll_index_box"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginStart="@dimen/dp_10"
                android:paddingBottom="@dimen/exam_item_margin_vertical"
                android:visibility="gone"/>

        </LinearLayout>
    </ScrollView>

    <!-- 遮罩层 -->
    <View
        android:id="@+id/v_mask"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#80999999"
        android:visibility="gone"/>

    <!-- 遮罩题号容器 -->
    <LinearLayout
        android:id="@+id/ll_mask_index_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="bottom"
        android:visibility="gone">

        <LinearLayout
            android:id="@+id/ll_mask_index_box"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="300dp"
            android:orientation="horizontal"
            android:background="#FFFFFF"
            android:padding="15dp"/>

    </LinearLayout>

</FrameLayout>
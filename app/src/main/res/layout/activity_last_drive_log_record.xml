<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:paddingTop="@dimen/dp_24"
    android:background="#FFFFFF">

    <!-- 标题栏 -->
    <include
        android:id="@+id/layout_title"
        layout="@layout/fragment_title" />

    <!-- 主内容滚动区域 -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="24dp"
        android:paddingVertical="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- 基本信息 -->
            <TextView
                android:id="@+id/tv_base_info_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="基本信息"
                android:textSize="17sp"
                android:background="#EEEEEE"
                android:padding="8dp"/>

            <!-- 日期 -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingVertical="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_vertical"
                    android:text="日期"
                    android:textSize="14sp"
                    android:textColor="#666666"/>

                <TextView
                    android:id="@+id/tv_addtime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2024-05-20 14:30:00"
                    android:textSize="14sp"
                    android:layout_gravity="end|center_vertical"/>

            </FrameLayout>

            <!-- 车牌号 -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingVertical="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="车牌号"
                    android:textSize="14sp"
                    android:textColor="#666666"/>

                <TextView
                    android:id="@+id/tv_carnum"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="鲁YUQ123"
                    android:textSize="14sp"
                    android:layout_gravity="end|center_vertical"/>

            </FrameLayout>

            <!-- 货物类型 -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingVertical="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="货物类型"
                    android:textSize="14sp"
                    android:textColor="#666666"/>

                <TextView
                    android:id="@+id/tv_goods_type"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="危险品"
                    android:textSize="14sp"
                    android:layout_gravity="end"/>

            </FrameLayout>

            <!-- 驾驶员姓名 -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingVertical="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="驾驶员姓名"
                    android:textSize="14sp"
                    android:textColor="#666666"/>

                <TextView
                    android:id="@+id/tv_driver_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="张三"
                    android:textSize="14sp"
                    android:layout_gravity="end"/>

            </FrameLayout>

            <!-- 押运员姓名 -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingVertical="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="押运员姓名"
                    android:textSize="14sp"
                    android:textColor="#666666"/>

                <TextView
                    android:id="@+id/tv_copilot_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="李四"
                    android:textSize="14sp"
                    android:layout_gravity="end"/>

            </FrameLayout>

            <!-- 天气情况 -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingVertical="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="天气情况"
                    android:textSize="14sp"
                    android:textColor="#666666"/>

                <TextView
                    android:id="@+id/tv_weather"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="晴"
                    android:textSize="14sp"
                    android:layout_gravity="end"/>

            </FrameLayout>

            <!-- 气温 -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingVertical="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="气温"
                    android:textSize="14sp"
                    android:textColor="#666666"/>

                <TextView
                    android:id="@+id/tv_temperature"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="25℃"
                    android:textSize="14sp"
                    android:layout_gravity="end"/>

            </FrameLayout>

            <!-- 行车前 -->
            <TextView
                android:id="@+id/tv_before_drive_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="行车前"
                android:textSize="17sp"
                android:background="#EEEEEE"
                android:padding="8dp"
                android:layout_marginTop="16dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="行车前安全员车辆检查事项件情况"
                android:textSize="14sp"
                android:layout_marginTop="8dp"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_before_drive"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                tools:itemCount="18"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_16"
                android:text="最终结果"
                android:textSize="14sp"/>

            <TextView
                android:id="@+id/tv_before_drive_result"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="良好，可以行驶"
                android:textSize="14sp"
                android:paddingVertical="16dp"/>

            <!-- 行车中 -->
            <TextView
                android:id="@+id/tv_driving_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="行车中"
                android:textSize="17sp"
                android:background="#EEEEEE"
                android:padding="8dp"
                android:layout_marginTop="16dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="行车中安全员车辆检查事项件情况"
                android:textSize="14sp"
                android:layout_marginTop="8dp"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_driving"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                tools:itemCount="11"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="最终结果"
                android:textSize="14sp"/>

            <TextView
                android:id="@+id/tv_driving_result"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="车辆和道路良好，可以继续行驶"
                android:textSize="14sp"
                android:paddingVertical="16dp"/>

            <!-- 收车后 -->
            <TextView
                android:id="@+id/tv_after_drive_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="收车后"
                android:textSize="17sp"
                android:background="#EEEEEE"
                android:padding="8dp"
                android:layout_marginTop="16dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="收车后车辆检查事项"
                android:textSize="14sp"
                android:layout_marginTop="8dp"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_after_drive"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                tools:itemCount="5"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="最终结果"
                android:textSize="14sp"/>

            <TextView
                android:id="@+id/tv_after_drive_result"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="良好，可以停放"
                android:textSize="14sp"
                android:paddingVertical="16dp"
                app:layout_constraintTop_toBottomOf="parent"/>

            <!-- 电子签名 -->
            <TextView
                android:id="@+id/tv_sign_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="电子签名"
                android:textSize="17sp"
                android:background="#EEEEEE"
                android:padding="8dp"
                android:layout_marginTop="16dp"/>

            <!-- 驾驶员签名 -->
            <TextView
                android:id="@+id/tv_driver_sign"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="驾驶员签名"
                android:textSize="14sp"/>

            <ImageView
                android:id="@+id/iv_driver_sign"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:scaleType="fitCenter"
                android:layout_marginTop="8dp"
                app:layout_constraintTop_toBottomOf="parent"
                tools:src="@drawable/ic_image_placeholder"/>

            <!-- 押运员签名 -->
            <TextView
                android:id="@+id/tv_copilot_sign"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="押运员签名"
                android:textSize="14sp"/>

            <ImageView
                android:id="@+id/iv_copilot_sign"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:scaleType="fitCenter"
                android:layout_marginTop="8dp"
                app:layout_constraintTop_toBottomOf="parent"
                tools:src="@drawable/ic_image_placeholder"/>

        </LinearLayout>

    </ScrollView>

</LinearLayout>
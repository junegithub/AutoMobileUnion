<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EEEEEE">

    <!-- 标题栏 -->
    <include
        android:id="@+id/layout_title"
        layout="@layout/fragment_title" />

    <!-- 主内容区域 -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/layout_title"
        app:layout_constraintBottom_toBottomOf="parent"
        android:paddingHorizontal="24dp"
        android:paddingVertical="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_last_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="上一次提交记录"
                android:textSize="18sp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"/>

            <!-- 上一次提交记录 -->
            <FrameLayout
                android:id="@+id/layout_last_record"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/card_bg_blue_light">

                <TextView
                    android:id="@+id/tv_last_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="2024-05-20 14:30:00"
                    android:textSize="20sp"
                    android:textColor="#333333"
                    android:layout_gravity="center"
                    android:layout_marginTop="8dp"/>

                <TextView
                    android:id="@+id/tv_last_car_num"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="鲁YUQ123"
                    android:textSize="16sp"
                    android:textColor="#666666"
                    android:layout_gravity="center"
                    android:layout_marginTop="@dimen/dp_32"/>

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="100dp"
                    android:src="@drawable/car_bg"
                    android:scaleType="fitXY"
                    android:layout_gravity="bottom"/>

            </FrameLayout>

            <!-- 新增日志 -->
            <FrameLayout
                android:id="@+id/layout_add_new"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/card_bg_blue">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_margin="@dimen/dp_16"
                    android:text="货运"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="end"
                    android:layout_margin="@dimen/dp_16"
                    android:text="*仅支持货运行业"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"/>

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/addicon"
                    android:layout_gravity="center"
                    android:layout_marginTop="8dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="新增日志"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:layout_gravity="center"
                    android:layout_marginTop="56dp"/>

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="100dp"
                    android:src="@drawable/car_bg"
                    android:scaleType="fitXY"
                    android:layout_gravity="bottom"/>

            </FrameLayout>

            <!-- 草稿箱容器 -->
            <FrameLayout
                android:id="@+id/drafts_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_16">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_vertical"
                    android:text="草稿箱"
                    android:textSize="18sp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="end|center_vertical"
                    android:text="最多存3条"
                    android:textSize="14sp"
                    android:textColor="#999999"/>

            </FrameLayout>

            <!-- 草稿箱列表 -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_drafts"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                tools:itemCount="2"/>

        </LinearLayout>

    </ScrollView>

    <!-- 草稿箱满弹窗 -->
    <include
        android:id="@+id/dialog_draft_full"
        layout="@layout/dialog_draft_full"
        android:visibility="gone"/>

    <!-- 删除确认弹窗 -->
    <include
        android:id="@+id/dialog_delete_confirm"
        layout="@layout/dialog_delete_confirm"
        android:visibility="gone"/>


</androidx.constraintlayout.widget.ConstraintLayout>

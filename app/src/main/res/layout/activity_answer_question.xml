<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="@color/white">

    <!-- 顶部导航栏 -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="?attr/colorPrimary">

        <!-- 答题模式/看题模式切换 -->
        <com.google.android.material.tabs.TabLayout
            android:id="@+id/tab_layout"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_gravity="center"
            app:tabSelectedTextColor="@color/primary"
            app:tabTextColor="@color/white"/>
    </androidx.appcompat.widget.Toolbar>

    <!-- 主内容区域（可滑动） -->
    <LinearLayout
        android:id="@+id/main_content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="@dimen/padding_4vw"
        android:clickable="true">

        <!-- 答题模式区域 -->
        <LinearLayout
            android:id="@+id/question_mode"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <!-- 题目信息头部 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingVertical="@dimen/padding_1vh"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tv_question_num"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="【全部】第1/10题目"
                    android:textSize="@dimen/text_34"/>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tv_right_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="对0"
                        android:textColor="@color/success_green"
                        android:textSize="@dimen/text_34"
                        android:paddingRight="@dimen/padding_2vw"/>

                    <TextView
                        android:id="@+id/tv_wrong_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="错0"
                        android:textColor="@color/error_red"
                        android:textSize="@dimen/text_34"
                        android:paddingRight="@dimen/padding_2vw"/>

                    <TextView
                        android:id="@+id/tv_view_all"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="查看"
                        android:textSize="@dimen/text_34"
                        android:clickable="true"
                        android:focusable="true"/>
                </LinearLayout>
            </LinearLayout>

            <!-- 题目内容滚动区域 -->
            <ScrollView
                android:id="@+id/sv_question_content"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:overScrollMode="never">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- 题目内容 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/padding_1vh"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:id="@+id/tv_question_type"
                            android:layout_width="@dimen/width_15vw"
                            android:layout_height="wrap_content"
                            android:text="单选题"
                            android:textSize="@dimen/text_26"
                            android:textColor="@color/error_red"
                            android:background="@color/error_bg"
                            android:gravity="center"
                            android:padding="@dimen/dp_4"
                            android:layout_marginRight="@dimen/padding_2vw"/>

                        <TextView
                            android:id="@+id/tv_question_text"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:textSize="@dimen/text_34"
                            android:text="题目内容"/>
                    </LinearLayout>

                    <!-- 选项列表 -->
                    <LinearLayout
                        android:id="@+id/ll_options"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginTop="@dimen/padding_2vh"/>

                    <!-- 答案解析区域 -->
                    <LinearLayout
                        android:id="@+id/ll_answer_analysis"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone"
                        android:layout_marginTop="@dimen/padding_2vh"
                        android:paddingTop="@dimen/padding_2vh">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="答案解析"
                                android:textSize="@dimen/text_34"/>

                            <TextView
                                android:id="@+id/tv_correct_answer"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="正确答案:A"
                                android:textSize="@dimen/text_34"/>
                        </LinearLayout>

                        <TextView
                            android:id="@+id/tv_analysis_text"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="解析内容"
                            android:textSize="@dimen/text_34"
                            android:layout_marginTop="@dimen/padding_3vh"/>
                    </LinearLayout>
                </LinearLayout>
            </ScrollView>

            <!-- 提交按钮 -->
            <Button
                android:id="@+id/btn_submit"
                android:layout_width="@dimen/width_80vw"
                android:layout_height="wrap_content"
                android:text="确定"
                android:backgroundTint="@color/primary"
                android:textColor="@color/white"
                android:layout_gravity="center"
                android:layout_marginBottom="@dimen/padding_2vh"
                android:visibility="gone"/>
        </LinearLayout>
    </LinearLayout>

    <!-- 遮罩层 -->
    <View
        android:id="@+id/v_mask"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#80000000"
        android:visibility="visible"/>

</LinearLayout>
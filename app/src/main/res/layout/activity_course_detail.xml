<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <!-- 视频播放区域 -->
    <FrameLayout
        android:id="@+id/flVideoContainer"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:visibility="gone">

        <!-- AndroidX Media3 PlayerView -->
        <androidx.media3.ui.PlayerView
            android:id="@+id/playerView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:show_buffering="always"
            app:show_shuffle_button="false"
            app:show_next_button="false"
            app:show_previous_button="false"
            app:use_controller="true"
            app:controller_layout_id="@layout/custom_exo_controller"/>

        <!-- 返回按钮 -->
        <ImageView
            android:id="@+id/ivBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_margin="16dp"
            android:src="@drawable/ic_arrow_left"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:elevation="4dp"/>
    </FrameLayout>

    <!-- 主内容滚动区域 -->
    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/flVideoContainer"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- 标题栏占位 -->
            <View
                android:id="@+id/vTitlePlaceholder"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:visibility="gone"/>

            <!-- 标题栏 -->
            <LinearLayout
                android:id="@+id/llTitleBar"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp"
                android:visibility="gone"
                android:background="@color/white">

                <ImageView
                    android:id="@+id/ivTitleBack"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/arrow_back"
                    android:layout_marginRight="16dp"/>

                <TextView
                    android:id="@+id/tvCourseName"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:textSize="18sp"
                    android:textColor="@color/text_333"
                    android:maxLines="1"
                    android:ellipsize="end"/>
            </LinearLayout>

            <!-- 课程信息 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tvCourseTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="20sp"
                    android:textColor="@color/text_333"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"
                    android:maxLines="2"
                    android:ellipsize="end"/>

                <!-- 时长信息 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:id="@+id/tvTotalTime"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="14sp"
                        android:textColor="@color/text_666"/>

                    <TextView
                        android:id="@+id/tvStudyTime"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="14sp"
                        android:textColor="@color/text_666"/>
                </LinearLayout>
            </LinearLayout>

            <!-- 评价按钮 -->
            <TextView
                android:id="@+id/tvEvaluate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="评价课件"
                android:textColor="@color/blue_3f83f7"
                android:textSize="14sp"
                android:gravity="end"
                android:padding="16dp"
                android:background="?attr/selectableItemBackground"/>

            <!-- 分割线 -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/gray_e7ebf9"/>

            <!-- 课程图片 -->
            <ImageView
                android:id="@+id/ivCourseImage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:adjustViewBounds="true"
                android:visibility="gone"
                android:scaleType="fitCenter"/>

            <!-- 其他课程列表 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="其他课程"
                    android:textSize="18sp"
                    android:textColor="@color/text_333"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp"/>

                <LinearLayout
                    android:id="@+id/llOtherCourses"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"/>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <!-- 清晰度切换弹窗 -->
    <LinearLayout
        android:id="@+id/llDefinitionMask"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@android:color/transparent"
        android:gravity="top|end"
        android:padding="20dp"
        android:visibility="gone"
        android:clickable="true">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@color/black_50"
            android:orientation="vertical"
            android:padding="10dp"
            android:radius="10dp">

            <TextView
                android:id="@+id/tvDefinitionSmooth"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="流畅"
                android:textColor="@color/white"
                android:padding="16dp"
                android:textSize="14sp"/>

            <TextView
                android:id="@+id/tvDefinitionStandard"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="标清"
                android:textColor="@color/white"
                android:padding="16dp"
                android:textSize="14sp"/>

            <TextView
                android:id="@+id/tvDefinitionHigh"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="高清"
                android:textColor="@color/white"
                android:padding="16dp"
                android:textSize="14sp"/>
        </LinearLayout>
    </LinearLayout>

    <!-- 评价弹窗 -->
    <LinearLayout
        android:id="@+id/llEvaluateMask"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/black_50"
        android:gravity="center"
        android:visibility="gone"
        android:clickable="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/white"
            android:orientation="vertical"
            android:padding="16dp"
            android:clickable="true"
            android:radius="10dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="评价内容"
                android:textSize="22sp"
                android:textColor="@color/text_333"
                android:gravity="center"
                android:paddingVertical="24dp"/>

            <EditText
                android:id="@+id/etEvaluateContent"
                android:layout_width="match_parent"
                android:layout_height="80dp"
                android:hint="输入评价内容"
                android:padding="16dp"
                android:background="@drawable/bg_edit_text"
                android:layout_marginVertical="24dp"
                android:gravity="top"
                android:maxLines="5"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvCancelEvaluate"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="取消"
                    android:gravity="center"
                    android:textSize="15sp"
                    android:background="@drawable/bg_button_white"
                    android:layout_marginRight="1dp"/>

                <TextView
                    android:id="@+id/tvConfirmEvaluate"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="确定"
                    android:gravity="center"
                    android:textSize="15sp"
                    android:textColor="@color/blue_3f83f7"
                    android:background="@drawable/bg_button_white"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

</RelativeLayout>
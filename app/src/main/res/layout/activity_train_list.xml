<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <include
            android:id="@+id/title_layout"
            layout="@layout/fragment_title" />

        <!-- 子Tab（进行中/历史）- 根据type决定是否显示 -->
        <com.google.android.material.tabs.TabLayout
            android:id="@+id/subTabLayout"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:background="#FFFFFF"
            android:visibility="gone"
            app:tabIndicatorColor="#2F67FF"
            app:tabIndicatorHeight="2dp"
            app:tabMode="fixed"
            app:tabPaddingStart="0dp"
            app:tabPaddingEnd="0dp"
            app:tabSelectedTextColor="#2F67FF"
            app:tabTextColor="@color/black"
            app:tabTextAppearance="@style/TabTextStyle">
            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="进行中" />

            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="历史" />
        </com.google.android.material.tabs.TabLayout>

        <!-- 主内容区域（直接使用RecyclerView，移除下拉刷新容器） -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_train_list"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:padding="16dp"/>

        <!-- 空数据 -->
        <LinearLayout
            android:id="@+id/emptyView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="数据为空"
                android:textSize="16sp"
                android:textColor="#999999"/>
        </LinearLayout>

        <!-- 加载更多底部 -->
        <TextView
            android:id="@+id/tvLoadMore"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_alignParentBottom="true"
            android:gravity="center"
            android:text="上拉加载更多"
            android:textSize="14sp"
            android:textColor="#999999"/>

    </LinearLayout>
    <!-- 个人中心入口 (右下角) -->
    <ImageView
        android:id="@+id/ivUser"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="40dp"
        android:src="@drawable/user_avatar"/>
</FrameLayout>

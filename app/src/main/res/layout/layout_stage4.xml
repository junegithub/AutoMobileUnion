<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <!-- 罐体检查 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="罐体检查 *（最多添加9张照片）"
            android:textColor="#000000"
            android:textSize="16sp" />

        <RadioGroup
            android:id="@+id/rg_canbody"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:background="#DCDFE6"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp">

            <RadioButton
                android:id="@+id/rb_canbody_ok"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_gravity="center_vertical"
                android:buttonTint="#2979FF"
                android:text="合格"
                android:textSize="16sp"
                android:checked="true"/>

            <RadioButton
                android:id="@+id/rb_canbody_no"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_gravity="center_vertical"
                android:layout_marginStart="24dp"
                android:buttonTint="#2979FF"
                android:text="不合格"
                android:textSize="16sp" />
        </RadioGroup>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_canbody_imgs"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginRight="8dp"
                app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
                app:spanCount="3"/>

            <ImageView
                android:id="@+id/btn_add_canbody"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:background="@drawable/bg_dashed_border"
                android:src="@drawable/ic_plus"
                android:scaleType="center"
                android:padding="20dp"/>
        </LinearLayout>
    </LinearLayout>

    <!-- 紧急切断阀检查 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="紧急切断阀检查 *（最多添加9张照片）"
            android:textColor="#000000"
            android:textSize="16sp" />

        <RadioGroup
            android:id="@+id/rg_cutoff"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:background="#DCDFE6"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp">

            <RadioButton
                android:id="@+id/rb_cutoff_ok"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_gravity="center_vertical"
                android:buttonTint="#2979FF"
                android:text="合格"
                android:textSize="16sp"
                android:checked="true"/>

            <RadioButton
                android:id="@+id/rb_cutoff_no"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_gravity="center_vertical"
                android:layout_marginStart="24dp"
                android:buttonTint="#2979FF"
                android:text="不合格"
                android:textSize="16sp" />
        </RadioGroup>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_cutoff_imgs"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginRight="8dp"
                app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
                app:spanCount="3"/>

            <ImageView
                android:id="@+id/btn_add_cutoff"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:background="@drawable/bg_dashed_border"
                android:src="@drawable/ic_plus"
                android:scaleType="center"
                android:padding="20dp"/>
        </LinearLayout>
    </LinearLayout>

    <!-- 导静电检查 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="导静电检查 *（最多添加9张照片）"
            android:textColor="#000000"
            android:textSize="16sp" />

        <RadioGroup
            android:id="@+id/rg_static"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:background="#DCDFE6"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp">

            <RadioButton
                android:id="@+id/rb_static_ok"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_gravity="center_vertical"
                android:buttonTint="#2979FF"
                android:text="合格"
                android:textSize="16sp"
                android:checked="true"/>

            <RadioButton
                android:id="@+id/rb_static_no"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_gravity="center_vertical"
                android:layout_marginStart="24dp"
                android:buttonTint="#2979FF"
                android:text="不合格"
                android:textSize="16sp" />
        </RadioGroup>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_static_imgs"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginRight="8dp"
                app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
                app:spanCount="3"/>

            <ImageView
                android:id="@+id/btn_add_static"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:background="@drawable/bg_dashed_border"
                android:src="@drawable/ic_plus"
                android:scaleType="center"
                android:padding="20dp"/>
        </LinearLayout>
    </LinearLayout>

    <!-- 运单检查 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="运单检查 *（最多添加9张照片）"
            android:textColor="#000000"
            android:textSize="16sp" />

        <RadioGroup
            android:id="@+id/rg_waybill"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:background="#DCDFE6"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp">

            <RadioButton
                android:id="@+id/rb_waybill_ok"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_gravity="center_vertical"
                android:buttonTint="#2979FF"
                android:text="合格"
                android:textSize="16sp"
                android:checked="true"/>

            <RadioButton
                android:id="@+id/rb_waybill_no"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:layout_gravity="center_vertical"
                android:layout_marginStart="24dp"
                android:buttonTint="#2979FF"
                android:text="不合格"
                android:textSize="16sp" />
        </RadioGroup>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_waybill_imgs"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginRight="8dp"
                app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
                app:spanCount="3"/>

            <ImageView
                android:id="@+id/btn_add_waybill"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:background="@drawable/bg_dashed_border"
                android:src="@drawable/ic_plus"
                android:scaleType="center"
                android:padding="20dp"/>
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/white">

    <!-- 标题栏 -->
    <include
        android:id="@+id/layout_title"
        layout="@layout/fragment_title" />

    <!-- 可滚动表单区域 -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="@dimen/dp_16"
            android:orientation="vertical">

            <!-- 姓名 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="姓名"
                android:textColor="@color/black"
                android:textSize="14sp"
                android:textStyle="bold"/>

            <EditText
                android:id="@+id/etNickname"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/et_gray_radius"
                android:paddingLeft="15dp"
                android:paddingRight="15dp"
                android:layout_marginTop="7.5dp"
                android:hint="请输入姓名"/>

            <!-- 手机号 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="手机号"
                android:layout_marginTop="@dimen/dp_16"
                android:textColor="@color/black"
                android:textSize="14sp"
                android:textStyle="bold"/>

            <EditText
                android:id="@+id/etMobile"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/et_gray_radius"
                android:paddingLeft="15dp"
                android:paddingRight="15dp"
                android:layout_marginTop="7.5dp"
                android:hint="请输入手机号"
                android:inputType="phone"/>

            <!-- 职位名称 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_16"
                android:text="职位名称"
                android:textColor="@color/black"
                android:textSize="14sp"
                android:textStyle="bold"/>

            <EditText
                android:id="@+id/etTitle"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:background="@drawable/et_gray_radius"
                android:paddingLeft="15dp"
                android:paddingRight="15dp"
                android:layout_marginTop="7.5dp"
                android:hint="请输入职位名称"/>

            <!-- 技能描述 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_16"
                android:text="技能描述"
                android:textColor="@color/black"
                android:textSize="14sp"
                android:textStyle="bold"/>

            <EditText
                android:id="@+id/etContent"
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:background="@drawable/et_gray_radius"
                android:paddingLeft="15dp"
                android:paddingRight="15dp"
                android:layout_marginTop="7.5dp"
                android:hint="请输入技能描述"
                android:gravity="top"
                android:inputType="textMultiLine"/>

            <!-- 证件上传区域 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_16"
                android:text="证件"
                android:textColor="@color/black"
                android:textSize="14sp"
                android:textStyle="bold"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="10dp">

                <!-- 身份证正面 -->
                <FrameLayout
                    android:id="@+id/flFrontCard"
                    android:layout_width="96dp"
                    android:layout_height="96dp"
                    android:background="@drawable/image_border">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="身份证正面"
                        android:textSize="14sp"
                        android:textColor="@color/gray_333"
                        android:layout_gravity="center"/>
                    <ImageView
                        android:id="@+id/ivFrontCard"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:visibility="gone"/>

                </FrameLayout>

                <!-- 身份证反面 -->
                <FrameLayout
                    android:id="@+id/flBackCard"
                    android:layout_width="96dp"
                    android:layout_height="96dp"
                    android:layout_marginLeft="10dp"
                    android:background="@drawable/image_border">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="身份证反面"
                        android:textSize="14sp"
                        android:textColor="@color/gray_333"
                        android:layout_gravity="center"/>
                    <ImageView
                        android:id="@+id/ivBackCard"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:visibility="gone"/>

                </FrameLayout>

                <!-- 驾驶证 -->
                <FrameLayout
                    android:id="@+id/flDrive"
                    android:layout_width="96dp"
                    android:layout_height="96dp"
                    android:layout_marginLeft="10dp"
                    android:background="@drawable/image_border">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="驾驶证"
                        android:textSize="14sp"
                        android:textColor="@color/gray_333"
                        android:layout_gravity="center"/>
                    <ImageView
                        android:id="@+id/ivDrive"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:visibility="gone"/>

                </FrameLayout>
            </LinearLayout>

            <!-- 从业资格证 -->
            <FrameLayout
                android:id="@+id/flDriving"
                android:layout_width="96dp"
                android:layout_height="96dp"
                android:layout_marginTop="@dimen/dp_16"
                android:background="@drawable/image_border">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="从业资格证"
                    android:textSize="14sp"
                    android:textColor="@color/gray_333"
                    android:layout_gravity="center"/>
                <ImageView
                    android:id="@+id/ivDriving"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:visibility="gone"/>

            </FrameLayout>
        </LinearLayout>
    </ScrollView>

    <!-- 提交按钮 -->
    <Button
        android:id="@+id/btnSubmit"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="确定"
        android:textColor="@color/white"
        android:textSize="14sp"
        android:background="@drawable/btn_submit_bg"
        android:layout_marginStart="@dimen/dp_16"
        android:layout_marginTop="@dimen/dp_16"
        android:layout_marginEnd="@dimen/dp_16"
        android:layout_marginBottom="@dimen/bottom_action_safe_spacing"/>
</LinearLayout>
